# Development: requests are proxied by Vite to localhost:3000
# Production (Vercel): NÃO definir VITE_API_URL no dashboard do Vercel.
# O vercel.json já faz proxy de /api/* para o Railway — o cookie fica
# first-party (same-origin) e funciona em Safari/iOS sem bloqueio ITP.
VITE_API_URL=http://localhost:3000/api
