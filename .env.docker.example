# PostgreSQL
DB_USER=postgres
DB_PASSWORD=mude_esta_senha
DB_NAME=fintech_db

# JWT (gerado com: openssl rand -hex 64)
JWT_SECRET=troque_este_segredo_por_algo_longo_e_aleatorio
JWT_EXPIRES_IN=7d

# Porta do host para acessar a aplicação (padrão: 80)
APP_PORT=80
